# ====================================================
#  Environment variables for rahulbk.com
#  Copy to .env.local for local dev, or paste into
#  Vercel → Settings → Environment Variables.
# ====================================================

# REQUIRED — Supabase project (the contact form writes here)
# Dashboard: https://supabase.com/dashboard/project/<project-id>/settings/api
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# REQUIRED — service_role key (server-only, never exposed to browser).
# This is NOT the anon key. It bypasses RLS by design — only used
# inside /api/contact.js which runs on Vercel's server runtime.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...REPLACE_ME

# OPTIONAL — notification email + Resend key. If both present,
# each contact form submission sends you an email. If absent,
# submissions still save to Supabase silently.
CONTACT_NOTIFY_EMAIL=rahulbabuk05@gmail.com
RESEND_API_KEY=re_REPLACE_ME
